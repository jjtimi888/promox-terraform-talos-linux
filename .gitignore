# Local .terraform path (contains downloaded providers and modules)
.terraform/

# .tfstate files (contains sensitive state data and credentials)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (often contain sensitive variables/secrets)
*.tfvars
*.tfvars.json

# Ignore override files (local overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Kubernetes credentials (CRITICAL: Do not commit sensitive cluster access configs)
kubeconfig
kubeconfig*

# Talos configuration/credentials (CRITICAL: Do not commit talos config with secrets)
talos_config.yaml
talosconfig
*talosconfig

# SSH keys or certificates if any
*.pem
*.key

# Temp files
*kube_config*
