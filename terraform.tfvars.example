# =============================================================================
# Proxmox
# =============================================================================
proxmox_endpoint = "https://192.168.100.252:8006/"
proxmox_insecure = true

# =============================================================================
# Talos Cluster
# =============================================================================
talos_cluster_name = "talos-cluster"
talos_version      = "1.13.5"

# =============================================================================
# Control Plane VMs
# =============================================================================
proxmox_control_vm_cores     = 2
proxmox_control_vm_memory    = 6144
proxmox_control_vm_disk_size = 20

# =============================================================================
# Worker VMs
# =============================================================================
proxmox_worker_vm_cores     = 1
proxmox_worker_vm_memory    = 2048
proxmox_worker_vm_disk_size = 10

# =============================================================================
# Node Definitions  (talos_node_name = "proxmox_node_name")
# =============================================================================
control_nodes = {
  "talos-control" = "pve"
}

worker_nodes = {
  "talos-worker-01" = "pve"
  "talos-worker-02" = "pve"
  "talos-worker-03" = "pve"
}

# =============================================================================
# MAC Addresses (for static DHCP assignment)
# =============================================================================
control_plane_mac_addresses = {
  "talos-control" = "BC:24:11:AA:BB:01"
}

worker_mac_addresses = {
  "talos-worker-01" = "BC:24:11:AA:BB:02"
  "talos-worker-02" = "BC:24:11:AA:BB:03"
  "talos-worker-03" = "BC:24:11:AA:BB:04"
}

# =============================================================================
# Cilium
# =============================================================================
cilium_version = "1.19.5"
lb_pool_start  = "192.168.100.200"
lb_pool_stop   = "192.168.100.240"

# =============================================================================
# Forgejo
# =============================================================================
forgejo_admin_user     = "git-admin"
forgejo_admin_password = "admin@6868"
forgejo_admin_email    = "git-admin@admin.com"
forgejo_ip             = "192.168.100.201"
forgejo_pin_node       = "talos-worker-01"
forgejo_org            = "homelab"
